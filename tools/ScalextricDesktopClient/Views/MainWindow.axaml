<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ScalextricDesktopClient.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="850" d:DesignHeight="600"
        x:Class="ScalextricDesktopClient.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Scalextric Desktop Client"
        Width="850" Height="600" MinWidth="700" MinHeight="400">

  <DockPanel Margin="10">

    <!-- Top: Transport selection + Connect -->
    <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,8">

      <DockPanel>
        <Button DockPanel.Dock="Right" x:Name="ConnectButton" Content="Connect"
                Click="OnConnectClick" Width="110" HorizontalContentAlignment="Center" Margin="8,0,0,0"/>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock Text="Transport:" VerticalAlignment="Center"/>
          <ComboBox ItemsSource="{Binding TransportNames}" SelectedItem="{Binding SelectedTransport}"
                    IsEnabled="{Binding CanConnect}" Width="120"/>
          <TextBlock Text="SYNC:" VerticalAlignment="Center" Margin="8,0,0,0"/>
          <NumericUpDown Value="{Binding SyncRounds}" Minimum="1" Maximum="50" Increment="1"
                         FormatString="0" Width="130" IsEnabled="{Binding CanConnect}"/>
          <TextBlock Text="{Binding Status}" VerticalAlignment="Center" Foreground="Gray"/>
        </StackPanel>
      </DockPanel>

      <!-- WebSocket config -->
      <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding IsWebSocket}">
        <TextBlock Text="URL (blank=auto):" VerticalAlignment="Center"/>
        <TextBox Text="{Binding WsUrl}" Width="300" Watermark="ws://192.168.1.100:81"
                 IsEnabled="{Binding CanConnect}"/>
      </StackPanel>

      <!-- Serial config -->
      <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding IsSerial}">
        <TextBlock Text="Port:" VerticalAlignment="Center"/>
        <ComboBox ItemsSource="{Binding SerialPorts}" SelectedItem="{Binding SelectedPort}"
                  IsEnabled="{Binding CanConnect}" Width="120"/>
        <Button Content="Refresh" Click="OnRefreshPorts" IsEnabled="{Binding CanConnect}"/>
      </StackPanel>

      <!-- BLE config -->
      <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding IsBle}">
        <Button Content="Scan" Click="OnBleScan" IsEnabled="{Binding CanConnect}"/>
        <ComboBox ItemsSource="{Binding BleDevices}" SelectedItem="{Binding SelectedBleDevice}"
                  IsEnabled="{Binding CanConnect}" Width="300"/>
      </StackPanel>

    </StackPanel>

    <!-- Stats bar -->
    <Border DockPanel.Dock="Top" Background="#20808080" CornerRadius="4" Padding="10,6" Margin="0,0,0,8">
      <StackPanel Orientation="Horizontal" Spacing="20">
        <TextBlock>
          <Run Text="Events: "/><Run Text="{Binding EventCount}"/>
        </TextBlock>
        <TextBlock>
          <Run Text="Dropped: "/><Run Text="{Binding DroppedCount}"/>
        </TextBlock>
        <TextBlock>
          <Run Text="Cars: "/><Run Text="{Binding CarCounts}"/>
        </TextBlock>
        <TextBlock>
          <Run Text="Avg Latency: "/><Run Text="{Binding AvgLatency}"/>
        </TextBlock>
        <TextBlock Foreground="Gray">
          <Run Text="{Binding CalibrationInfo}"/>
        </TextBlock>
      </StackPanel>
    </Border>

    <!-- Bottom: Log panel -->
    <Border DockPanel.Dock="Bottom" Background="#10808080" CornerRadius="4" Padding="6" Margin="0,8,0,0"
            Height="120">
      <ListBox ItemsSource="{Binding LogLines}" x:Name="LogList" FontSize="11" FontFamily="Consolas"
               BorderThickness="0" Background="Transparent"/>
    </Border>

    <!-- Event grid -->
    <DataGrid ItemsSource="{Binding Events}" IsReadOnly="True" CanUserSortColumns="False"
              GridLinesVisibility="Horizontal" BorderThickness="1" BorderBrush="#40808080"
              HeadersVisibility="Column">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Time" Binding="{Binding TimeStr}" Width="Auto"/>
        <DataGridTextColumn Header="Node" Binding="{Binding NodeName}" Width="Auto"/>
        <DataGridTextColumn Header="Sensor" Binding="{Binding SensorId, StringFormat=S{0}}" Width="Auto"/>
        <DataGridTextColumn Header="Car" Binding="{Binding CarLabel}" Width="Auto"/>
        <DataGridTextColumn Header="Freq" Binding="{Binding Frequency, StringFormat={}{0} Hz}" Width="Auto"/>
        <DataGridTextColumn Header="Latency" Binding="{Binding LatencyStr}" Width="Auto"/>
        <DataGridTextColumn Header="Queue" Binding="{Binding InternalDelayStr}" Width="Auto"/>
        <DataGridTextColumn Header="Seq" Binding="{Binding Sequence}" Width="Auto"/>
        <DataGridTextColumn Header="Recv ms" Binding="{Binding EspRecvMillis}" Width="Auto"/>
        <DataGridTextColumn Header="Send ms" Binding="{Binding EspSendMillis}" Width="*"/>
      </DataGrid.Columns>
    </DataGrid>

  </DockPanel>
</Window>
